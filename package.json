    "url": "https://github.com/Codename-11/model-foundry/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Codename-11/model-foundry.git"
  },
  "license": "MIT",
  "author": "Codename-11",
  "type": "module",
  "main": "bin/modelrelay.js",
  "bin": {
